# Data for working environment cleanliness - should refactor to sqlite
# Anchored to repo root so it doesn't also ignore tests/data/ (test code).
# Ignore the data dir's contents but keep the tracked schema file.
/data/*
!/data/db_population.py
output/
*.csv
*.png
*.jpg
*.jpeg
# ...but keep the README demo screenshots (tracked despite the global *.png ignore)
!/docs/screenshots/
!/docs/screenshots/*.png

# Large media: keep video out of git (exceeds GitHub's 100 MB file limit).
# The full demo video can stay locally but is never committed; the README
# uses docs/demo.gif + docs/screenshots/ instead.
*.mp4

# OS
.DS_Store
Thumbs.db

